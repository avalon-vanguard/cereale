  "bugs": {
    "url": "https://github.com/Avalon-Vanguard/optimus/issues"
  },
  "homepage": "https://github.com/Avalon-Vanguard/optimus#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
