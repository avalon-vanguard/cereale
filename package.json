{
  "name": "optimus",
  "version": "1.0.0",
  "description": "Spring-like decorators for JSON mapping and validation in TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "demo": "ts-node src/example.ts",
